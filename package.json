{
  "name": "gitship",
  "version": "1.0.0",
  "description": "Ship your frontend from Git to production - Docker container for building and deploying frontend projects",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "gitship": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "commander": "^12.0.0",
    "execa": "^9.0.0",
    "hono": "^4.0.0",
    "js-yaml": "^4.1.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
